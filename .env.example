# =============================================================
# Silo Coverage Designer — env template
# VPS では /opt/kw/.env に実値を投入。GitHub には絶対に載せない。
# =============================================================

# --- Runtime ---
NODE_ENV=production
PORT=4050
LOG_LEVEL=info

# --- KW専有DB ---
DB_PATH=./db/kw.db

# --- 共有データ層（/opt/shared、Daiki承認 案A） ---
# ローカル開発時は ./db/voyage-cache.db / ./db/serp-cache.db でも可
SHARED_VOYAGE_CACHE_PATH=/opt/shared/voyage-cache.db
SHARED_SERP_CACHE_PATH=/opt/shared/serp-cache.db

# --- 外部API（cannibalization と同値を流用可: Voyage / Anthropic / SerpAPI / Google） ---
VOYAGE_API_KEY=
ANTHROPIC_API_KEY=
SERPAPI_KEY=

# Google: NLP API + Search Console（サービスアカウントJSON）
GOOGLE_APPLICATION_CREDENTIALS=./.secrets/gcp-service-account.json
GSC_PROPERTY_URL=

# --- Ahrefs（[L2]のみ・[L1]では使わない・Daiki提供）---
AHREFS_API_TOKEN=
# 月次ユニット予算（config tableに同期する初期値）
AHREFS_UNIT_BUDGET_MONTHLY=150000

# --- Claude モデル ---
ANTHROPIC_MODEL=claude-opus-4-7

# --- LLM fan-out 模擬 ---
FANOUT_SUBQUERIES_MIN=8
FANOUT_SUBQUERIES_MAX=20
